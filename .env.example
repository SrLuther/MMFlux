FLUXOS_ADMIN_USER=admin
FLUXOS_ADMIN_PASS=admin123
FLUXOS_SECRET=troque-por-um-segredo-forte

# Chave da Google Cloud Vision API (OCR de comprovantes de ponto)
# Obtenha em: https://console.cloud.google.com/apis/credentials
# Deixe em branco para usar Tesseract local como fallback
GOOGLE_VISION_KEY=

# ── WhatsApp Service ──────────────────────────────────────────────────────────
# URL do serviço WhatsApp local (padrão: 127.0.0.1:3001 — não expor externamente)
WHATSAPP_NOTIFY_URL=http://127.0.0.1:3001/notify

# Porta do serviço WhatsApp (deve corresponder a WHATSAPP_NOTIFY_URL)
WA_PORT=3001

# Número que receberá alertas internos do sistema (startup, erros).
# Formato: apenas dígitos, sem código do país (ex: 75991234567)
WA_ALERT_PHONE=
